# ════════════════════════════════════════════════════════════════════
#   TX/Coreum Validator Monitor — Environment Variables
#   Copy this file to .env for local dev, or paste into Railway/Fly.io
# ════════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Your validator operator address (starts with corevaloper1...)
# Find this in your wallet or on https://www.mintscan.io/coreum/validators
VALIDATOR_ADDRESS=corevaloper1your_address_here

# Telegram bot token — get this from the COREZ Buy Bot (see README)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID — see README for how to find yours
TELEGRAM_CHAT_ID=your_chat_id_here

# ── OPTIONAL — Indexer API ────────────────────────────────────────────────────
# If you're running the Coreezy Indexer (or a compatible TX indexer API),
# point to it here for richer data (uptime %, missed blocks, voting power).
# If left blank, the monitor uses the public LCD node automatically.
INDEXER_API_URL=
INDEXER_API_KEY=

# ── OPTIONAL — Chain ──────────────────────────────────────────────────────────
# Public LCD node — works out of the box, no changes needed for most users
LCD_URL=https://tx-chain-rest.publicnode.com

# ── OPTIONAL — Polling & Thresholds ──────────────────────────────────────────
# How often to check (milliseconds). Default: 600000 = 10 minutes
CHECK_INTERVAL_MS=600000

# How often to send the full digest summary (hours). Default: 4
SUMMARY_INTERVAL_HOURS=4

# Alert if uptime drops below this % (requires indexer). Default: 99.0
UPTIME_ALERT_THRESHOLD=99.0

# Alert if voting power shifts by this % (requires indexer). Default: 5.0
VOTING_POWER_CHANGE_PCT=5.0

# Alert if total staked TX changes by this amount. Default: 50000
STAKED_CHANGE_ALERT_TX=50000

# Alert if missed blocks increases by this much in one check. Default: 10
MISSED_BLOCKS_ALERT=10

# Alert on any rank change. Default: 1 (any change). Increase to reduce noise.
RANK_CHANGE_ALERT=1
